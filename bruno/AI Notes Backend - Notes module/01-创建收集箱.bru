meta {
  name: 01-创建收集箱
  type: http
  seq: 1
}
post {
  url: {{baseUrl}}/api/notes
  body: none
  auth: bearer
}
auth:bearer {
  token: {{accessToken}}
}
assert {
  res.status: eq 201
  res.body.data.id: isDefined
}
script:post-response {
  if (res.getStatus() === 201) {
    bru.setEnvVar("currentNoteId", res.getBody().data.id);
  }
}
