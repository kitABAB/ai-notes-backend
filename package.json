{
  "name": "ai-notes-backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio --port 7433",
    "db:check": "drizzle-kit check",
    "test": "cd \"bruno/AI Notes Backend - Auth module\" && bru run --env develop",
    "test:report": "cd \"bruno/AI Notes Backend - Auth module\" && bru run --env develop --reporter-html ../../report.html"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@hono/zod-validator": "^0.8.0",
    "ai": "^6.0.191",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.21",
    "ioredis": "^5.11.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@usebruno/cli": "^3.4.0",
    "drizzle-kit": "^0.31.10"
  }
}